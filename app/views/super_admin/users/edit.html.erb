<div class="dashboard">
  <%= render "shared/navbar" %>
  <div class="dashboard-body">
    <%= render "shared/sidebar", current_tab: nil %>
    <main class="dashboard-main">
      <div class="dashboard-card">
        <div class="page-header">
          <h1 class="page-title">Edit user</h1>
          <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            <%= link_to "Back to users", super_admin_users_path, class: "btn-secondary" %>
            <% unless @user.id == Current.user.id %>
              <%= link_to "Delete", super_admin_user_path(@user), data: { turbo_method: :delete, turbo_confirm: "Delete this user? They will no longer be able to sign in." }, class: "btn-danger" %>
            <% end %>
          </div>
        </div>
        <div class="form-card">
          <%= render "form", user: @user %>
        </div>
      </div>
    </main>
  </div>
</div>
